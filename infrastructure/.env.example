# ============================================================
# GeoArbitrage HQ — Umgebungsvariablen
# Kopiere diese Datei nach .env und fuelle alle Werte aus:
#   cp .env.example .env
# ============================================================

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=YOUR_N8N_PASSWORD
N8N_HOST=YOUR_TAILSCALE_HOSTNAME
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_EDITOR_BASE_URL=https://YOUR_TAILSCALE_HOSTNAME
WEBHOOK_URL=https://webhook.YOUR_DOMAIN.com
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
NODES_EXCLUDE=[]
N8N_DEFAULT_EXECUTION_TIMEOUT=-1

# --- PostgreSQL (n8n-intern) ---
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=YOUR_POSTGRES_PASSWORD

# --- Supabase ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
MODEL_SONNET=claude-sonnet-4-6
MODEL_HAIKU=claude-haiku-4-5-20251001

# --- Voyage AI (Embeddings) ---
VOYAGE_API_KEY=YOUR_VOYAGE_API_KEY

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_SECRET_TOKEN=YOUR_TELEGRAM_SECRET_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID
TELEGRAM_ALLOWED_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# --- Google Calendar (OAuth2) ---
GOOGLE_CALENDAR_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CALENDAR_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# --- Tavily Web Search (fuer Weekly Scan) ---
TAVILY_API_KEY=YOUR_TAVILY_API_KEY

# --- Optional: ACLED (Konflikdaten) ---
ACLED_USERNAME=YOUR_ACLED_EMAIL
ACLED_PASSWORD=YOUR_ACLED_PASSWORD

# ============================================================
# WICHTIG:
# - JEDE neue Variable muss AUCH in docker-compose.yml unter
#   n8n -> environment eingetragen werden!
# - Nach Aenderungen: docker compose up -d (NICHT restart!)
# - Service Role Key NIEMALS im Frontend verwenden!
# ============================================================
